page {
  min-height: 100vh;
  background: #fcf9f2;
  color: #181f19;
  font-family: "Noto Serif SC", "Songti SC", serif;
  -webkit-font-smoothing: antialiased;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  line-height: 1;
  border-radius: 0;
  background: transparent;
}

button::after {
  border: 0;
}

.screen {
  min-height: 100vh;
  padding: 128rpx 64rpx 180rpx;
  position: relative;
  overflow: hidden;
}

.paper-grain {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 0;
  pointer-events: none;
  opacity: 0.08;
  background-image: radial-gradient(#1a1c1a 0.7rpx, transparent 0.8rpx);
  background-size: 28rpx 28rpx;
}

.app-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  min-height: 112rpx;
  padding: calc(env(safe-area-inset-top) + 18rpx) 56rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(252, 249, 242, 0.82);
  backdrop-filter: blur(16rpx);
}

.app-title {
  max-width: 470rpx;
  color: #181f19;
  font-size: 32rpx;
  line-height: 40rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  text-align: center;
  white-space: nowrap;
}

.icon-button {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #181f19;
  font-family: Arial, sans-serif;
  font-size: 42rpx;
}

.bottom-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 25;
  height: calc(132rpx + env(safe-area-inset-bottom));
  padding: 16rpx 64rpx calc(18rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(252, 249, 242, 0.9);
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -8rpx 36rpx rgba(45, 52, 46, 0.08);
  backdrop-filter: blur(18rpx);
}

.nav-item {
  min-width: 112rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  color: rgba(74, 93, 80, 0.62);
  font-family: Arial, sans-serif;
  font-size: 22rpx;
}

.nav-item.active {
  color: #181f19;
  transform: scale(1.06);
}

.nav-icon {
  font-size: 38rpx;
  line-height: 38rpx;
}

.primary-button,
.ghost-button,
.danger-link {
  min-height: 96rpx;
  padding: 0 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  border-radius: 8rpx;
  font-family: Arial, sans-serif;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.primary-button {
  color: #f4f1ea;
  background: #181f19;
  box-shadow: 0 16rpx 36rpx rgba(24, 31, 25, 0.18);
}

.primary-button[disabled],
.ghost-button[disabled] {
  opacity: 0.48;
}

.ghost-button {
  color: #181f19;
  border: 1rpx solid rgba(105, 93, 74, 0.55);
}

.danger-link {
  min-height: 72rpx;
  color: #8c7e6a;
  font-size: 24rpx;
  font-style: italic;
  font-weight: 400;
}

.section-label {
  display: block;
  color: #8c7e6a;
  font-family: Arial, sans-serif;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
  text-transform: uppercase;
}

.narrative-title {
  color: #181f19;
  font-size: 56rpx;
  line-height: 74rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.narrative-body {
  color: #1c1c18;
  font-size: 34rpx;
  line-height: 60rpx;
  letter-spacing: 1rpx;
}

.inner-text {
  color: #695d4a;
  font-size: 30rpx;
  line-height: 52rpx;
  font-style: italic;
}

.ui-text {
  color: #444844;
  font-family: Arial, sans-serif;
  font-size: 26rpx;
  line-height: 40rpx;
}

.soft-card {
  position: relative;
  z-index: 1;
  padding: 48rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.42);
  box-shadow: 0 24rpx 56rpx rgba(45, 52, 46, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.55);
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip {
  min-height: 48rpx;
  padding: 10rpx 20rpx;
  display: inline-flex;
  align-items: center;
  border-radius: 999rpx;
  font-family: Arial, sans-serif;
  font-size: 24rpx;
  line-height: 30rpx;
}

.chip.dark {
  color: #f4f1ea;
  background: #4a5d50;
}

.chip.line {
  color: #444844;
  border: 1rpx solid #c4c7c2;
}

.chip.warm {
  color: #504534;
  background: rgba(242, 224, 200, 0.58);
}

.field {
  width: 100%;
  min-height: 96rpx;
  padding: 24rpx 0;
  color: #181f19;
  border-bottom: 1rpx solid rgba(116, 120, 115, 0.42);
  font-family: Arial, sans-serif;
  font-size: 30rpx;
  line-height: 44rpx;
}

.textarea-field {
  width: 100%;
  min-height: 180rpx;
  padding: 28rpx;
  color: #181f19;
  border: 1rpx solid rgba(116, 120, 115, 0.28);
  border-radius: 8rpx;
  background: rgba(246, 243, 236, 0.64);
  font-family: Arial, sans-serif;
  font-size: 28rpx;
  line-height: 44rpx;
}

.fade-up {
  animation: fadeUp 420ms ease-out both;
}

@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(18rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
