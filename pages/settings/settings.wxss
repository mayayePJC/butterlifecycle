.settings-screen {
  padding-bottom: 120rpx;
}

.settings-card,
.prompt-card {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.helper {
  display: block;
}

.switch-row {
  min-height: 104rpx;
  padding: 24rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid rgba(196, 199, 194, 0.4);
  border-bottom: 1rpx solid rgba(196, 199, 194, 0.4);
}

.switch-title,
.field-label {
  display: block;
  color: #181f19;
  font-family: Arial, sans-serif;
  font-size: 28rpx;
  font-weight: 700;
}

.switch-desc,
.key-note {
  display: block;
  margin-top: 10rpx;
  color: rgba(68, 72, 68, 0.68);
  font-family: Arial, sans-serif;
  font-size: 22rpx;
  line-height: 34rpx;
}

.field-group {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.prompt-card {
  margin-top: 42rpx;
}

.rule {
  color: #444844;
  font-size: 28rpx;
  line-height: 46rpx;
}
