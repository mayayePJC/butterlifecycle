<view class="screen settings-screen">
  <view class="paper-grain"></view>

  <view class="app-bar">
    <button class="icon-button" bindtap="back">‹</button>
    <text class="app-title">设置</text>
    <button class="icon-button" bindtap="noop"> </button>
  </view>

  <view class="soft-card settings-card fade-up">
    <text class="narrative-title">云端续写</text>

    <view class="switch-row">
      <view>
        <text class="switch-title">启用 AI</text>
      </view>
      <switch checked="{{config.enabled}}" color="#4A5D50" bindchange="onEnabledChange" />
    </view>

    <view class="field-group">
      <text class="field-label">AI 代理 HTTPS 域名</text>
      <input class="field" value="{{config.proxyUrl}}" placeholder="https://你的正式自定义域名" bindinput="onProxyUrlInput" />
      <text class="field-hint">云托管默认域名仅用于调试，正式版请使用已绑定的自定义域名。</text>
    </view>

    <button class="primary-button" bindtap="save">保存设置</button>
    <button class="ghost-button" loading="{{testing}}" disabled="{{testing}}" bindtap="testAi">测试 AI 连接</button>
    <button class="ghost-button" bindtap="disableAi">关闭 AI</button>
  </view>
</view>
