.story-screen {
  padding: 0;
}

.story-scroll {
  height: 100vh;
  position: relative;
  z-index: 1;
}

.story-content {
  padding: 164rpx 64rpx 760rpx;
}

.beat {
  position: relative;
  margin-bottom: 88rpx;
}

.beat-number {
  position: absolute;
  left: -52rpx;
  top: 6rpx;
  color: rgba(140, 126, 106, 0.26);
  font-family: Arial, sans-serif;
  font-size: 28rpx;
  font-weight: 700;
}

.action-recap {
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  color: #8c7e6a;
  font-family: Arial, sans-serif;
  font-size: 23rpx;
  line-height: 34rpx;
}

.scene {
  display: block;
}

.inner-note {
  margin: 58rpx 0 30rpx;
  padding-left: 38rpx;
  color: #695d4a;
  border-left: 1rpx solid rgba(196, 199, 194, 0.54);
  font-size: 30rpx;
  line-height: 54rpx;
  font-style: italic;
}

.pressure-text {
  display: block;
  color: rgba(68, 72, 68, 0.76);
  font-family: Arial, sans-serif;
  font-size: 26rpx;
  line-height: 42rpx;
}

.stream-panel {
  padding: 34rpx;
  border: 1rpx solid rgba(105, 93, 74, 0.22);
  background: rgba(246, 243, 236, 0.48);
}

.stream-dots {
  display: flex;
  gap: 10rpx;
}

.stream-dots text {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #4a5d50;
  animation: streamPulse 900ms ease-in-out infinite;
}

.stream-dots text:nth-child(2) {
  animation-delay: 120ms;
}

.stream-dots text:nth-child(3) {
  animation-delay: 240ms;
}

.stream-text {
  display: block;
  margin-top: 20rpx;
  color: #444844;
  font-size: 30rpx;
  line-height: 52rpx;
}

.choice-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  max-height: 56vh;
  padding: 20rpx 44rpx calc(22rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
  background: rgba(252, 249, 242, 0.94);
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -18rpx 60rpx rgba(45, 52, 46, 0.1);
  backdrop-filter: blur(18rpx);
}

.choice-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.choice-button {
  width: 100%;
  min-height: 92rpx;
  padding: 20rpx 24rpx;
  text-align: left;
  border: 1rpx solid rgba(105, 93, 74, 0.24);
  background: rgba(255, 255, 255, 0.2);
}

.choice-button[disabled] {
  opacity: 0.5;
}

.choice-head {
  display: flex;
  gap: 18rpx;
  justify-content: space-between;
  align-items: center;
  color: #181f19;
  font-family: Arial, sans-serif;
  font-size: 26rpx;
  line-height: 42rpx;
  font-weight: 400;
}

.custom-action {
  margin-top: 22rpx;
  min-height: 86rpx;
  padding-bottom: 12rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  border-bottom: 1rpx solid rgba(116, 120, 115, 0.42);
}

.custom-icon {
  color: #8c7e6a;
  font-size: 34rpx;
}

.custom-input {
  flex: 1;
  min-width: 0;
  color: #181f19;
  font-family: Arial, sans-serif;
  font-size: 25rpx;
  line-height: 38rpx;
}

.custom-send {
  width: 96rpx;
  min-height: 48rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #f4f1ea;
  background: #181f19;
  border-radius: 999rpx;
  font-family: Arial, sans-serif;
  font-size: 24rpx;
  font-weight: 700;
}

.custom-send[disabled] {
  color: rgba(68, 72, 68, 0.34);
  background: transparent;
  border: 1rpx solid rgba(116, 120, 115, 0.2);
  opacity: 1;
}

.end-link {
  margin: 18rpx auto 0;
}

@keyframes streamPulse {
  0%,
  100% {
    opacity: 0.28;
    transform: translateY(0);
  }
  50% {
    opacity: 1;
    transform: translateY(-4rpx);
  }
}
