.story-screen {
  padding: 0;
}

.story-scroll {
  height: 100vh;
  position: relative;
  z-index: 1;
}

.story-content {
  padding: 164rpx 64rpx 620rpx;
}

.beat {
  position: relative;
  margin-bottom: 88rpx;
}

.beat-number {
  position: absolute;
  left: -52rpx;
  top: 6rpx;
  color: rgba(140, 126, 106, 0.26);
  font-family: Arial, sans-serif;
  font-size: 28rpx;
  font-weight: 700;
}

.action-recap {
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  color: #8c7e6a;
  font-family: Arial, sans-serif;
  font-size: 23rpx;
  line-height: 34rpx;
}

.scene {
  display: block;
}

.inner-note {
  margin: 58rpx 0 30rpx;
  padding-left: 38rpx;
  color: #695d4a;
  border-left: 1rpx solid rgba(196, 199, 194, 0.54);
  font-size: 30rpx;
  line-height: 54rpx;
  font-style: italic;
}

.pressure-text {
  display: block;
  color: rgba(68, 72, 68, 0.76);
  font-family: Arial, sans-serif;
  font-size: 26rpx;
  line-height: 42rpx;
}

.stream-panel {
  padding: 34rpx;
  border: 1rpx solid rgba(105, 93, 74, 0.22);
  background: rgba(246, 243, 236, 0.48);
}

.stream-text {
  display: block;
  margin-top: 20rpx;
  color: #444844;
  font-size: 30rpx;
  line-height: 52rpx;
}

.choice-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  max-height: 72vh;
  padding: 22rpx 56rpx calc(26rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
  background: rgba(252, 249, 242, 0.94);
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -18rpx 60rpx rgba(45, 52, 46, 0.1);
  backdrop-filter: blur(18rpx);
}

.status-strip {
  min-height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid rgba(196, 199, 194, 0.48);
}

.status-copy {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  color: #181f19;
  font-family: Arial, sans-serif;
  font-size: 24rpx;
  line-height: 34rpx;
}

.status-small {
  color: rgba(140, 126, 106, 0.78);
  font-size: 20rpx;
}

.status-arrow {
  color: #8c7e6a;
  font-size: 34rpx;
}

.hidden-tray {
  padding: 24rpx 0 10rpx;
}

.status-item {
  margin-bottom: 18rpx;
}

.status-head {
  margin-bottom: 8rpx;
  display: flex;
  justify-content: space-between;
  color: #444844;
  font-family: Arial, sans-serif;
  font-size: 22rpx;
}

.status-bar {
  height: 10rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e5e2db;
}

.status-fill {
  height: 100%;
  border-radius: 999rpx;
}

.choice-list {
  padding-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.choice-button {
  width: 100%;
  min-height: 136rpx;
  padding: 28rpx 32rpx;
  text-align: left;
  border: 1rpx solid rgba(105, 93, 74, 0.24);
  background: rgba(255, 255, 255, 0.2);
}

.choice-button[disabled] {
  opacity: 0.5;
}

.choice-head {
  display: flex;
  justify-content: space-between;
  color: #181f19;
  font-family: Arial, sans-serif;
  font-size: 28rpx;
  line-height: 38rpx;
  font-weight: 700;
}

.choice-copy {
  display: block;
  margin-top: 16rpx;
  color: #444844;
  font-family: Arial, sans-serif;
  font-size: 24rpx;
  line-height: 38rpx;
}

.custom-action {
  margin-top: 30rpx;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  border-bottom: 1rpx solid rgba(116, 120, 115, 0.42);
}

.custom-icon {
  color: #8c7e6a;
  font-size: 34rpx;
}

.custom-input {
  flex: 1;
  color: #181f19;
  font-family: Arial, sans-serif;
  font-size: 28rpx;
}

.custom-send {
  width: 88rpx;
  color: #181f19;
  font-family: Arial, sans-serif;
  font-size: 24rpx;
  text-align: right;
}

.end-link {
  margin: 28rpx auto 0;
}
