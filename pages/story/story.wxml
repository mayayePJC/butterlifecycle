<view class="screen story-screen">
  <view class="paper-grain"></view>

  <view class="app-bar">
    <button class="icon-button" bindtap="goHome">×</button>
    <text class="app-title">蝴蝶人生</text>
    <button class="icon-button" bindtap="goSettings">•••</button>
  </view>

  <scroll-view scroll-y class="story-scroll" scroll-into-view="{{scrollIntoView}}" enhanced>
    <view class="story-content">
      <view wx:for="{{beats}}" wx:key="id" class="beat" id="beat-{{item.turn}}">
        <view class="beat-number">{{item.turnText}}</view>
        <view wx:if="{{item.action}}" class="action-recap">
          <text>{{item.action.text}}</text>
        </view>
        <text class="narrative-body scene">{{item.scene}}</text>
        <view class="inner-note">
          <text>“{{item.innerReaction}}”</text>
        </view>
        <text class="pressure-text">{{item.pressure}}</text>
      </view>

      <view wx:if="{{streaming}}" class="stream-panel" id="streaming">
        <text class="stream-text">{{streamText || "她的下一段人生正在浮现..."}}</text>
      </view>

      <view id="story-bottom"></view>
    </view>
  </scroll-view>

  <view class="choice-panel">
    <view class="choice-list">
      <button wx:for="{{choices}}" wx:key="text" class="choice-button" disabled="{{streaming}}" data-index="{{index}}" bindtap="chooseOption">
        <view class="choice-head">
          <text>{{item.text}}</text>
          <text>→</text>
        </view>
      </button>
    </view>

    <view class="custom-action">
      <text class="custom-icon">≋</text>
      <input class="custom-input" value="{{customAction}}" placeholder="或者，写下你的选择..." disabled="{{streaming}}" bindinput="onCustomInput" confirm-type="send" bindconfirm="sendCustom" />
      <button class="custom-send" disabled="{{streaming || !customAction}}" bindtap="sendCustom">确认</button>
    </view>

    <button class="danger-link end-link" disabled="{{streaming}}" bindtap="finishStory">到此为止 ×</button>
  </view>
</view>
