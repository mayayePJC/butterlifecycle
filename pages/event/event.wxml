<view class="screen event-screen">
  <view class="paper-grain"></view>

  <view class="app-bar event-app-bar">
    <button class="icon-button" bindtap="back">‹</button>
    <text class="event-nav-spacer"></text>
    <button class="icon-button" bindtap="goSettings">•••</button>
  </view>

  <view class="event-card fade-up">
    <text class="event-text">{{event.text}}</text>
    <view class="event-note">
      <text>“{{event.innerReaction}}”</text>
    </view>
    <text class="pressure">{{event.pressure}}</text>
  </view>

  <view class="custom-event">
    <text class="section-label">Custom Event</text>
    <textarea class="textarea-field" value="{{customText}}" maxlength="180" placeholder="或者，写下她今天遇到的一件小事..." bindinput="onCustomInput"></textarea>
  </view>

  <view class="action-stack">
    <button class="ghost-button" bindtap="nextEvent">⟳ 换一个事件</button>
    <button class="ghost-button" bindtap="useCustom">使用自定义事件</button>
    <button class="primary-button" bindtap="startStory">让她活下去 →</button>
  </view>
</view>
