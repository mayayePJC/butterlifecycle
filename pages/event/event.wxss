.event-screen {
  padding-top: calc(env(safe-area-inset-top) + 168rpx);
  padding-bottom: 160rpx;
}

.event-card {
  margin-top: 24rpx;
  padding: 48rpx;
  position: relative;
  z-index: 1;
  border: 1rpx solid rgba(105, 93, 74, 0.2);
  background: rgba(246, 243, 236, 0.4);
}

.event-text {
  display: block;
  color: #181f19;
  font-size: 36rpx;
  line-height: 64rpx;
}

.event-note {
  margin: 56rpx 0 36rpx;
  padding-left: 34rpx;
  border-left: 1rpx solid rgba(196, 199, 194, 0.58);
  color: #695d4a;
  font-size: 30rpx;
  line-height: 52rpx;
  font-style: italic;
}

.pressure {
  display: block;
  color: #444844;
  font-family: Arial, sans-serif;
  font-size: 26rpx;
  line-height: 42rpx;
}

.custom-event {
  margin-top: 48rpx;
  position: relative;
  z-index: 1;
}

.custom-event .textarea-field {
  margin-top: 24rpx;
}

.action-stack {
  margin-top: 56rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
